# Cloudflare Pages / Workers Environment Variables

# --- STRIPE CONFIGURATION ---
# Your Stripe API Secret Key (e.g. sk_test_...)
STRIPE_SECRET_KEY=sk_test_...
# Your Stripe Webhook Signing Secret (e.g. whsec_...) for webhook verification
STRIPE_WEBHOOK_SECRET=whsec_...

# --- GOOGLE SHEETS CONFIGURATION ---
# The ID of your Google Spreadsheet (found in the sheet URL)
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here
# The Service Account Email (e.g. client-email@project.iam.gserviceaccount.com)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account_email@project.iam.gserviceaccount.com
# The Private Key of the Service Account (enclose in quotes, make sure it includes newlines or is formatted correctly)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC7...\n-----END PRIVATE KEY-----\n"

# --- RESEND CONFIGURATION (EMAILS) ---
# Your Resend API Key (re_...)
RESEND_API_KEY=re_...
# The sender email address (must be verified in Resend, e.g. "Szervezők <info@yourdomain.com>")
EMAIL_FROM="Esemény Szervező <info@yourdomain.com>"

# --- EVENT DETAILS ---
EVENT_NAME="OHANA"
EVENT_DATE="2026. augusztus 7. (péntek) 18:00–21:45"
EVENT_LOCATION="Scruton (1053 Budapest, Veres Pálné utca 12.)"
TICKET_PRICE_HUF=18000
MAX_TICKETS=35
